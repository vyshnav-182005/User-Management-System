NODE_ENV=development
PORT=5000
# Use either MONGO_URI or MONGODB_URI
MONGO_URI=mongodb://127.0.0.1:27017/user_management_system
# MONGODB_URI=mongodb://127.0.0.1:27017/user_management_system
CORS_ORIGIN=http://localhost:5173

# Cookie settings (important for deployed frontend + backend on different domains)
# For cross-site cookies in production, use: COOKIE_SAME_SITE=none and COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
# Optional. Set only when you need a specific cookie domain.
COOKIE_DOMAIN=

JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_ACCESS_EXPIRES_IN=15m

# Optional refresh token support
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

# Optional bootstrap admin user
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=ChangeThisStrongPassword123!
